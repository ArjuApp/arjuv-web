---
import Logo from '../components/Logo.astro';
import LogoArjuv from '../components/LogoArjuv.astro';
---

<nav
  id="navbar"
  class="fixed top-0 left-0 w-full z-50 bg-white px-8 py-4 transition-all duration-300 border-b border-gray-200/60"
>
  <div class="max-w-7xl mx-auto flex items-center justify-between">
    <!-- Logo izquierda -->
    <div class="shrink-0">
      <a href="/">
        <Logo class="h-10 w-auto" color="#002991" />
      </a>
    </div>

    <!-- Links centrados -->
    <ul class="hidden md:flex items-center gap-8">
      <li>
        <a href="#home" class="text-gray-700 hover:text-primary font-medium transition-colors">
          Inicio
        </a>
      </li>
      <li>
        <a href="#services" class="text-gray-700 hover:text-primary font-medium transition-colors">
          ¿Qué Ofrecemos?
        </a>
      </li>
      <li>
        <a href="#ours" class="text-gray-700 hover:text-primary font-medium transition-colors">
          Nuestra Cultura
        </a>
      </li>
      <li>
        <a href="#process" class="text-gray-700 hover:text-primary font-medium transition-colors">
          ¿Cómo Trabajamos?
        </a>
      </li>
      <li>
        <a href="#benefits" class="text-gray-700 hover:text-primary font-medium transition-colors">
          Beneficios
        </a>
      </li>
    </ul>

    <!-- Logo letras derecha -->
    <div class="shrink-0">
      <a href="/">
        <LogoArjuv class="h-8 w-auto" color="#002991" />
      </a>
    </div>
  </div>
</nav>


<div class="h-[72px]"></div>
