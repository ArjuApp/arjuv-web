---
import LogoArjuv from '../components/LogoArjuv.astro';
import heroImage from '../assets/hero.jpg';
---

<section id="home" class="relative bg-blue-100 h-[200vh]">
  
  <div id="hero-pin" class="h-screen flex flex-col items-center justify-center md:justify-start overflow-hidden sticky top-0">
  
    <h1
      id="hero-title"
      class="text-4xl sm:text-4xl md:text-5xl lg:text-8xl font-bold text-gray-900 text-center max-w-6xl leading-tight mt-0 md:mt-40 px-4 sm:px-6 z-10"
    >
      Impulsamos tu crecimiento creando mejores experiencias
    </h1>

  
    <div
      id="hero-card"
      class="absolute bottom-0 translate-y-1/3 w-[85vw] sm:w-[70vw] md:w-md h-[50vh] sm:h-[45vh] md:h-auto rounded-2xl md:rounded-3xl bg-white shadow-2xl overflow-hidden z-20 flex flex-col"
    >
  
      <div class="flex items-center justify-center py-3 sm:py-4 px-4 sm:px-6 border-b border-gray-100">
        <LogoArjuv class="h-6 sm:h-8 w-auto" color="#002991" />
      </div>
  
      <div class="w-full flex-1 min-h-0 relative overflow-hidden">
        <img
          src={heroImage.src}
          alt="Hero"
          class="w-full h-full object-cover"
        />
        <h2
          id="hero-cta-text"
          class="absolute bottom-4 right-4 sm:bottom-8 sm:right-6 md:bottom-16 md:right-8 text-2xl sm:text-3xl md:text-4xl lg:text-6xl xl:text-8xl font-bold text-white translate-x-[110%]"
        >
          ¿Listo para modernizar?
        </h2>
      </div>
    </div>
  </div>
</section>

<style>
    h1 {
		font-family: 'Montserrat Variable', sans-serif;
        line-height: 1;
	}

    h2 {
        font-family: 'Montserrat Variable', sans-serif;
    }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const heroSection = document.getElementById('home');
  const heroTitle = document.getElementById('hero-title');
  const heroCard = document.getElementById('hero-card');
  const heroCtaText = document.getElementById('hero-cta-text');

  if (heroSection && heroTitle && heroCard && heroCtaText) {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: heroSection,
        start: 'top top',
        end: 'bottom bottom',
        scrub: 1,
        pin: '#hero-pin',
      },
    });

    // Card: sube desde abajo (translateY 50% → 0) y se expande al ancho/alto completo
    tl.to(
      heroCard,
      {
        y: 0,
        width: '100%',
        height: '100%',
        borderRadius: '0px',
        duration: 1,
        ease: 'none',
      },
      0
    );

    // Título: se reduce y sube hasta desaparecer
    tl.to(
      heroTitle,
      {
        scale: 0.6,
        y: -200,
        opacity: 0,
        duration: 1,
        ease: 'none',
      },
      0
    );

    // Texto CTA: se desliza desde fuera (derecha) hacia dentro de la tarjeta
    tl.to(
      heroCtaText,
      {
        xPercent: 0,
        x: 0,
        duration: 0.2,
        ease: 'none',
      },
      0.8
    );
  }
</script>
