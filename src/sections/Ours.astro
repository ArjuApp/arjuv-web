---
const cards = [
  {
    title: 'Innovación',
    description: 'Exploramos nuevas tecnologías y enfoques para ofrecer soluciones que marcan la diferencia.',
  },
  {
    title: 'Calidad',
    description: 'Cada decisión de diseño refleja nuestro compromiso con la excelencia.',
  },
  {
    title: 'Compromiso',
    description: 'Nos involucramos como parte de tu equipo, entendiendo tus metas como propias.',
  },
  {
    title: 'Crecimiento',
    description: 'Construimos soluciones escalables que acompañan la evolución de tu negocio.',
  },
  {
    title: 'Modernización',
    description: 'Transformamos sistemas heredados en plataformas ágiles y preparadas para el futuro.',
  },
];
---

<section id="ours-section" class="relative bg-blue-50 py-24 px-6 overflow-hidden">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-16">
    
    <!-- Izquierda: burbujas giratorias -->
    <div class="md:w-1/2 flex items-center justify-center">
      <div id="ours-orbit" class="relative w-[360px] h-[360px]">
        <!-- Centro visual -->
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="w-3 h-3 rounded-full bg-primary/30"></div>
        </div>
        {cards.map((card, index) => (
          <div
            class="ours-bubble absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[130px] h-[130px] rounded-full bg-white shadow-md border border-gray-100 flex flex-col items-center justify-center text-center p-3 transition-shadow duration-300"
            data-index={index}
          >
            <h4 class="text-xs font-bold text-primary mb-1 leading-tight">{card.title}</h4>
            <p class="text-[10px] text-gray-500 leading-tight">{card.description}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Derecha: título y descripción -->
    <div class="md:w-1/2">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 leading-tight mb-6">
        Creamos tecnología con propósito
      </h2>
      <p class="text-lg md:text-xl text-gray-600 leading-relaxed">
        Creemos que la tecnología solo tiene sentido cuando genera valor para las personas. 
        Diseñamos soluciones que simplifican procesos, fortalecen la relación con los clientes 
        y ayudan a las empresas a crecer de forma sostenible.
      </p>
    </div>
  </div>
</section>

<style>
  h2, h4 {
    font-family: 'Montserrat Variable', sans-serif;
  }

  .ours-bubble.highlighted {
    box-shadow: 0 8px 30px rgba(0, 41, 145, 0.2), 0 4px 12px rgba(0, 0, 0, 0.06);
    transform: translate(-50%, -50%) scale(1.1);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const orbit = document.getElementById('ours-orbit');
  const bubbles = document.querySelectorAll('.ours-bubble');
  const totalBubbles = bubbles.length;
  const radius = 130; // radio de la órbita

  if (orbit && totalBubbles > 0) {
    // Posición inicial: distribuir en círculo
    const angleStep = (2 * Math.PI) / totalBubbles;

    bubbles.forEach((bubble, i) => {
      const angle = i * angleStep;
      const x = Math.cos(angle) * radius;
      const y = Math.sin(angle) * radius;
      gsap.set(bubble, { x, y });
    });

    // Animación de rotación orbital con scroll
    ScrollTrigger.create({
      trigger: '#ours-section',
      start: 'top 80%',
      end: 'bottom 20%',
      scrub: 1,
      onUpdate: (self) => {
        const progress = self.progress;
        const rotationOffset = progress * Math.PI * 2; // una vuelta completa

        bubbles.forEach((bubble, i) => {
          const angle = i * angleStep + rotationOffset;
          const x = Math.cos(angle) * radius;
          const y = Math.sin(angle) * radius;
          gsap.set(bubble, { x, y });

          // Resaltar la burbuja más cercana al frente (arriba)
          const normalizedAngle = ((angle % (2 * Math.PI)) + 2 * Math.PI) % (2 * Math.PI);
          const isTop = normalizedAngle > (3 * Math.PI / 2 - 0.4) && normalizedAngle < (3 * Math.PI / 2 + 0.4);
          
          if (isTop) {
            bubble.classList.add('highlighted');
          } else {
            bubble.classList.remove('highlighted');
          }
        });
      },
    });
  }
</script>
