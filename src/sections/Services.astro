---
import { Icon } from 'astro-icon/components';

import Service1 from '../assets/Service1.jpg';
import Service2 from '../assets/Service2.jpg';
import Service3 from '../assets/Service3.jpg';
import Service4 from '../assets/Service4.jpg';
import Service5 from '../assets/Service5.jpg';
import Service6 from '../assets/Service6.jpg';
import Service7 from '../assets/Service7.jpg';

import LittleTitle from '../components/LittleTitle.astro';


const services = [
  {
    title: 'Software Impulsado con IA',
    description: 'Desarrollamos soluciones inteligentes que aprenden y se adaptan para optimizar cada aspecto de tu negocio.',
    icon: 'lucide:brain-circuit',
    image: Service1
  },
  {
    title: 'Automatización de Procesos',
    description: 'Eliminamos tareas repetitivas y agilizamos flujos de trabajo para que tu equipo se enfoque en lo que importa.',
    icon: 'lucide:cog',
    image: Service2
  },
  {
    title: 'Integraciones',
    description: 'Conectamos tus sistemas y herramientas existentes para crear un ecosistema digital unificado y eficiente.',
    icon: 'lucide:plug',
    image: Service3
  },
  {
    title: 'Software Empresarial',
    description: 'Construimos plataformas robustas y escalables que resuelven los desafíos únicos de tu organización.',
    icon: 'lucide:building-2',
    image: Service4
  },
  {
    title: 'Aplicaciones Móviles',
    description: 'Creamos experiencias móviles nativas e intuitivas que conectan con tus usuarios donde sea que estén.',
    icon: 'lucide:smartphone',
    image: Service5
  },
  {
    title: 'Aplicaciones Web',
    description: 'Diseñamos aplicaciones web modernas, rápidas y accesibles que impulsan la productividad.',
    icon: 'lucide:globe',
    image: Service6
  },
  {
    title: 'Cloud y DevOps',
    description: 'Implementamos infraestructura en la nube con prácticas DevOps para despliegues seguros y continuos.',
    icon: 'lucide:cloud',
    image: Service7
  },
];
---

<section id="services" class="relative bg-white" style={`height: ${services.length * 30 + 100}vh;`}>
  
  <div id="services-pin" class="h-screen flex flex-col items-center justify-start px-6 overflow-hidden sticky top-0">
  
    
    <LittleTitle title='¿Qué Ofrecemos?' className='mt-24' />
  
    <h2 class="text-2xl md:text-3xl lg:text-5xl font-bold text-primary mt-12 text-center  max-w-4xl mb-12">
      Todo lo que tu empresa necesita para crecer
    </h2>

    <!-- Layout de dos columnas -->
    <div class="max-w-6xl w-full flex flex-col md:flex-row items-start gap-24 mt-16">
      
      <!-- Títulos a la izquierda: efecto rueda -->
      <div class="md:w-1/2 relative h-[420px] overflow-hidden flex items-center justify-center">
        <div id="services-wheel" class="relative w-full mr-20">
          {services.map((service, index) => (
            <div
              class="service-title absolute w-full text-center md:text-left left-0"
              data-index={index}
              style="top: 50%; transform: translateY(-50%);"
            >
              <h3 class="text-2xl md:text-3xl text-right font-bold text-gray-200 transition-colors duration-300 whitespace-nowrap">
                {service.title}
              </h3>
            </div>
          ))}
        </div>
      </div>

      <!-- Cards a la derecha -->
      <div class="md:w-1/2 relative h-[420px]">
        {services.map((service, index) => (
          <div
            class="service-card absolute inset-0 opacity-0"
            data-index={index}
          >
            <div class="bg-blue-50 rounded-2xl shadow-lg border border-gray-100 h-full flex flex-col justify-end relative overflow-hidden">

                <img src={service.image.src} class="object-bottom w-full h-full" />
              
              <div class="p-8">
                <div class="flex items-center gap-4 mb-5">
                    <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
                    <Icon name={service.icon} class="w-6 h-6 text-primary" />
                    </div>
                    <h4 class="text-lg font-semibold text-gray-900">{service.title}</h4>
                </div>
                <p class="text-gray-600 text-base leading-relaxed">
                    {service.description}
                </p>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  h2, h3, h4 {
    font-family: 'Montserrat Variable', sans-serif;
  }

  .service-title.active h3 {
    color: #111827;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const servicesSection = document.getElementById('services');
  const servicesPin = document.getElementById('services-pin');
  const titles = document.querySelectorAll('.service-title');
  const cards = document.querySelectorAll('.service-card');
  const totalServices = titles.length;
  const ITEM_SPACING = 70; // px entre cada título

  if (servicesSection && servicesPin && totalServices > 0) {
    let currentIndex = 0;

    // Estado inicial: posicionar todos los títulos en rueda
    titles.forEach((title, i) => {
      const offset = i * ITEM_SPACING;
      gsap.set(title, { y: offset, opacity: i === 0 ? 1 : 0.4 });
      if (i === 0) title.classList.add('active');
    });

    // Primera card visible
    gsap.set(cards[0], { opacity: 1 });

    ScrollTrigger.create({
      trigger: servicesSection,
      start: 'top top',
      end: 'bottom bottom',
      pin: false,
      scrub: 0.5,
      onUpdate: (self) => {
        const progress = self.progress;

        // Posición continua del "foco" (interpolada)
        const floatIndex = progress * (totalServices - 1);
        const newIndex = Math.min(Math.round(floatIndex), totalServices - 1);

        // Mover todos los títulos continuamente (efecto rueda)
        titles.forEach((title, i) => {
          const relativePos = (i - floatIndex) * ITEM_SPACING;
          gsap.set(title, {
            y: relativePos,
            opacity: Math.abs(i - floatIndex) < 0.5 ? 1 : 0.7,
          });
        });

        // Cambiar card cuando cambia el índice activo
        if (newIndex !== currentIndex) {
          titles[currentIndex].classList.remove('active');
          gsap.to(cards[currentIndex], { opacity: 0, duration: 0.25, overwrite: true });

          titles[newIndex].classList.add('active');
          gsap.to(cards[newIndex], { opacity: 1, duration: 0.25, overwrite: true });

          currentIndex = newIndex;
        }
      },
    });
  }
</script>
