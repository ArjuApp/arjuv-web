---
import LogoArjuv from '../components/LogoArjuv.astro';
import Logo from '../components/Logo.astro';
import { Icon } from 'astro-icon/components';
---

<footer class="bg-primary text-white py-16 px-6">
  <div class="max-w-6xl mx-auto">

    <div class="flex items-center justify-center gap-2 mb-10">
        <Logo class="h-12 w-auto" color="#ffffff" />
        <LogoArjuv class="h-12 w-auto" color="#ffffff" />
        </div>

    <!-- Contenido principal -->
    <div class="flex flex-col md:flex-row justify-between items-center md:items-start gap-12 mb-12">
      <!-- Izquierda: Logo + contacto + redes -->
      <div class="flex flex-col items-center md:items-start gap-6">
        <!-- Logo blanco -->
         

        <!-- Información de contacto -->
        <div class="flex flex-col sm:flex-row items-center gap-2 text-sm text-white/80">
            <div class="flex items-center gap-2">
                <Icon name="lucide:mail" class="w-5 h-5" />
                <a href="mailto:contacto@arjuv.com" class="hover:text-white transition-colors">
                  contacto@arjuv.com
                </a>
            </div>

            <div class="flex items-center gap-2">
                <Icon name="lucide:phone" class="w-5 h-5" />
                <a href="tel:+573001234567" class="hover:text-white transition-colors">
                  +57 312 345 6607
                </a>
            </div>

        </div>

        <!-- Redes sociales -->
        <div class="flex items-center gap-4">
          <a href="#" class="text-white/70 hover:text-white transition-colors" aria-label="Instagram">
            <Icon name="lucide:instagram" class="w-5 h-5" />
          </a>
          <a href="#" class="text-white/70 hover:text-white transition-colors" aria-label="Twitter">
            <Icon name="lucide:twitter" class="w-5 h-5" />
          </a>
          <a href="#" class="text-white/70 hover:text-white transition-colors" aria-label="Facebook">
            <Icon name="lucide:facebook" class="w-5 h-5" />
          </a>
        </div>
      </div>

      <!-- Derecha: Links de navegación -->
       <div class="text-center md:text-left">
           <h4 class="text-sm font-semibold text-white/50 uppercase tracking-wider mb-2">Navegación</h4>
           <div class="flex flex-col md:flex-row items-center md:items-start gap-3">
             <a href="#home" class="text-sm text-white/80 hover:text-white transition-colors">Inicio</a>
             <a href="#services" class="text-sm text-white/80 hover:text-white transition-colors">¿Qué Ofrecemos?</a>
             <a href="#ours" class="text-sm text-white/80 hover:text-white transition-colors">Nuestra Cultura</a>
             <a href="#process" class="text-sm text-white/80 hover:text-white transition-colors">¿Cómo Trabajamos?</a>
             <a href="#benefits" class="text-sm text-white/80 hover:text-white transition-colors">Beneficios</a>
           </div>
       </div>
    </div>

    <!-- Separador -->
    <div class="border-t border-white/20 pt-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <!-- Copyright -->
        <p class="text-md text-white/60">
          © 2026 Arjuv. Todos los derechos reservados.
        </p>
        <!-- Slogan -->
        <p class="text-md font-medium text-white/60 italic">
          "Creando Mejores Experiencias"
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  h4 {
    font-family: 'Montserrat Variable', sans-serif;
  }
</style>
