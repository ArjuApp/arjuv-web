---

interface Props {

    title: string;
    className?: string;
}

const { title, className } = Astro.props; 

---

<h4 class={`text-2xl after:bg-primary font-bold ${className}`}>
    {title}
</h4>

<style>

    h4 {
        font-family: 'Montserrat Variable', sans-serif;
    }

    h4::after {
        content: '';
        display: block;
        width: 100%;
        height: 4px;
        border-radius: 50px;
        margin-top: 2px;
    }

</style>



